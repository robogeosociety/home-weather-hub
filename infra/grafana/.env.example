# Copy to /Volumes/dev/grafana/.env and fill in.

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<32-char random string>

# Same token value as INFLUX_GRAFANA_TOKEN in infra/influxdb/.env.
# Substituted into provisioning/datasources/influxdb.yml at container start.
INFLUX_GRAFANA_TOKEN=<read-only token covering all archive buckets>
