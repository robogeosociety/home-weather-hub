    {
      "id": 5,
      "type": "timeseries",
      "title": "Temperature & Humidity",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 8},
      "datasource": {"type": "influxdb", "uid": "tempest_archive"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "tempest_archive"},
          "query": "from(bucket: \"tempest_archive\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather\" and r._field == \"air_temp_c\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _value: r._value * 1.8 + 32.0 }))"
        },
        {
          "refId": "B",
          "datasource": {"type": "influxdb", "uid": "tempest_archive"},
          "query": "from(bucket: \"tempest_archive\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather\" and r._field == \"humidity_pct\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": {"mode": "palette-classic"}
        },
        "overrides": [
          {
            "matcher": {"id": "byFrameRefID", "options": "A"},
            "properties": [
              {"id": "unit", "value": "fahrenheit"},
              {"id": "displayName", "value": "Air Temp (°F)"},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}
            ]
          },
          {
            "matcher": {"id": "byFrameRefID", "options": "B"},
            "properties": [
              {"id": "unit", "value": "humidity"},
              {"id": "displayName", "value": "Humidity (%)"},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}},
              {"id": "custom.axisPlacement", "value": "right"}
            ]
          }
        ]
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": ["min", "max", "mean", "lastNotNull"]}
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Wind (avg / gust / lull)",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "influxdb", "uid": "tempest_archive"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "tempest_archive"},
          "query": "from(bucket: \"tempest_archive\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather\" and (r._field == \"wind_avg_mps\" or r._field == \"wind_gust_mps\" or r._field == \"wind_lull_mps\"))\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "velocityms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": {"mode": "palette-classic"}
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": ".*wind_gust.*"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}, {"id": "displayName", "value": "Gust"}]},
          {"matcher": {"id": "byRegexp", "options": ".*wind_avg.*"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}, {"id": "displayName", "value": "Average"}]},
          {"matcher": {"id": "byRegexp", "options": ".*wind_lull.*"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}, {"id": "displayName", "value": "Lull"}]}
        ]
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": ["max", "mean", "lastNotNull"]}
      }
    },
    {
      "id": 7,
