      "type": "stat",
      "title": "API Errors (cumulative)",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "influxdb", "uid": "transit_tracker"},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "influxdb", "uid": "transit_tracker"},
        "query": "from(bucket: \"transit_tracker\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"service_counter\" and r.name == \"api_errors_total\" and r._field == \"value\")\n  |> last()"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
