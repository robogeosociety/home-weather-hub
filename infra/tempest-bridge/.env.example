# Copy to ~/.local/share/tempest-bridge/.env (chmod 600).
# Must live in the home dir because launchd's TCC sandbox blocks /Volumes/* paths.

INFLUX_TEMPEST_TOKEN=<write-bucket tempest_archive token>

# Optional overrides — defaults baked into bridge.sh.
# INFLUX_URL=http://localhost:8086
# INFLUX_BUCKET=tempest_archive
# UDP_PORT=50222
