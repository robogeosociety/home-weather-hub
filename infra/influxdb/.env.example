# Copy to /Volumes/dev/influxdb/.env and fill in.
# All fields are generated on first boot of the influxdb container
# (DOCKER_INFLUXDB_INIT_MODE=setup); the values below are read by docker-compose
# and become the admin's identity. Persist these somewhere safe — InfluxDB
# stores hashed copies and you can't recover them.

INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=<32-char random string>
INFLUX_ORG=home
INFLUX_BUCKET=home_assistant
INFLUX_ADMIN_TOKEN=<64-char random string>

# Service tokens minted after first boot via `influx auth create` (see README).
# Append these to this file as you create them so they're easy to rotate.
INFLUX_HA_TOKEN=<write-bucket home_assistant>
INFLUX_TEMPEST_TOKEN=<write-bucket tempest_archive>
INFLUX_GRAFANA_TOKEN=<read-bucket tempest_archive,home_assistant,zigbee_archive>

# Cloudflare R2 credentials for off-host backup sync (see backup-r2-sync.sh).
# Mint an R2 API token in the Cloudflare dashboard
# (https://dash.cloudflare.com/?to=/:account/r2/api-tokens) with permission
# "Object Read & Write" scoped to the influxdb-backups bucket.
R2_ACCOUNT_ID=<32-char Cloudflare account id>
R2_ACCESS_KEY_ID=<token access key id>
R2_SECRET_ACCESS_KEY=<token secret>
R2_BUCKET=influxdb-backups
